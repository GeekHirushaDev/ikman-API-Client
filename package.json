{
  "name": "ikman-api-client",
  "version": "2.0.3",
  "description": "Complete API client for ikman.lk - search listings, read individual ads, batch processing, and sorting methods",
  "main": "src/index.js",
  "types": "src/types.d.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "check": "npm run lint && npm test -- --runInBand",
    "example": "node examples/search.js",
    "example:ad": "node examples/single-ad.js",
    "example:batch": "node examples/batch.js",
    "example:advanced": "node examples/advanced.js",
    "example:images": "node examples/images.js",
    "try:all": "npm run check && npm run example && npm run example:ad && npm run example:batch && npm run example:advanced",
    "prepublishOnly": "npm test && npm run lint"
  },
  "keywords": [
    "ikman",
    "client",
    "api",
    "marketplace",
    "sri-lanka",
    "classifieds",
    "ads",
    "real-estate",
    "cars",
    "electronics"
  ],
  "author": "GeekHirushaDev <admin@geekhirusha.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeekHirushaDev/ikman-API-Client.git"
  },
  "bugs": {
    "url": "https://github.com/GeekHirushaDev/ikman-API-Client/issues"
  },
  "homepage": "https://github.com/GeekHirushaDev/ikman-API-Client#readme",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.3",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.0.3",
    "joi": "^17.9.2",
    "jsdom": "^22.1.0",
    "ora": "^5.4.1",
    "p-queue": "^7.3.4",
    "p-retry": "^5.1.2",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.0.0",
    "nock": "^13.3.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
